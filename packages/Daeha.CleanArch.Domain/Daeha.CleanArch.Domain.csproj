<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>Daeha.CleanArch.Domain</PackageId>
    <Version>1.0.0</Version>
    <Authors>Daeha</Authors>
    <Description>Clean Architecture Domain foundations: Result pattern, BaseEntity, AggregateRoot, ValueObject, DomainEvent, and marker interfaces.</Description>
    <PackageTags>cleanarchitecture;ddd;domain;result</PackageTags>
    <RepositoryUrl>https://github.com/daeha76/claude-forge</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

</Project>

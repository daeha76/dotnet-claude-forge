<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>Daeha.CleanArch.Infrastructure</PackageId>
    <Version>1.0.0</Version>
    <Authors>Daeha</Authors>
    <Description>Clean Architecture Infrastructure: BaseDbContext with multi-tenant global filters, audit columns, CurrentUserService (JWT), and DI extensions.</Description>
    <PackageTags>cleanarchitecture;efcore;postgresql;multitenant</PackageTags>
    <RepositoryUrl>https://github.com/daeha76/claude-forge</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Daeha.CleanArch.Application\Daeha.CleanArch.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="EFCore.NamingConventions" Version="10.0.1" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.3" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.0" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

</Project>

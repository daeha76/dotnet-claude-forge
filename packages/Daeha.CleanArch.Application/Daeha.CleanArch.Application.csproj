<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>Daeha.CleanArch.Application</PackageId>
    <Version>1.0.0</Version>
    <Authors>Daeha</Authors>
    <Description>Clean Architecture Application layer: MediatR pipeline behaviors (Logging, Validation, Authorization, Transaction) and core interfaces.</Description>
    <PackageTags>cleanarchitecture;cqrs;mediatr;fluentvalidation</PackageTags>
    <RepositoryUrl>https://github.com/daeha76/claude-forge</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Daeha.CleanArch.Domain\Daeha.CleanArch.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation" Version="12.1.1" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" Version="12.1.1" />
    <PackageReference Include="MediatR" Version="14.1.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.0" />
  </ItemGroup>

</Project>

using {{name}}.Application;
using {{name}}.Infrastructure;
using Daeha.CleanArch.Api.Extensions;
using Microsoft.AspNetCore.RateLimiting;
using Microsoft.OpenApi;
using Serilog;
using Serilog.Events;
using System.Threading.RateLimiting;

// в”Җв”Җв”Җ Serilog л¶ҖнҠёмҠӨнҠёлһ© лЎңкұ° (DI мқҙм „ м—җлҹ¬ мәЎмІҳ) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
Log.Logger = new LoggerConfiguration()
    .MinimumLevel.Override("Microsoft", LogEventLevel.Information)
    .Enrich.FromLogContext()
    .WriteTo.Console()
    .CreateBootstrapLogger();

try
{
    var builder = WebApplication.CreateBuilder(args);

    // в”Җв”Җв”Җ Azure Key Vault (Staging/Production мһҗлҸҷ нҷңм„ұнҷ”) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.AddAzureKeyVault();

    // в”Җв”Җв”Җ Serilog (Console + n8n Webhook мЎ°кұҙл¶Җ нҷңм„ұнҷ”) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // n8n Webhook: Serilog:N8nWebhookUrl м„Өм • мӢңм—җл§Ң мһҗлҸҷ нҷңм„ұнҷ”
    builder.Host.UseSerilog((ctx, services, lc) =>
    {
        lc.ReadFrom.Configuration(ctx.Configuration)
          .ReadFrom.Services(services)
          .Enrich.FromLogContext()
          .Enrich.WithProperty("Application", "{{name}}")
          .Enrich.WithProperty("Environment", ctx.HostingEnvironment.EnvironmentName);

        var webhookUrl = ctx.Configuration["Serilog:N8nWebhookUrl"];
        if (!string.IsNullOrEmpty(webhookUrl))
        {
            lc.WriteTo.Http(
                requestUri: webhookUrl,
                queueLimitBytes: null,
                restrictedToMinimumLevel: LogEventLevel.Error);
        }
    });

    // в”Җв”Җв”Җ Data Protection (к°ңл°ң: лЎңм»¬, мҡҙмҳҒ: Azure Blob + Key Vault) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddDataProtectionAzure(builder.Configuration, builder.Environment);

    // в”Җв”Җв”Җ Application + Infrastructure в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddApplication();
    builder.Services.AddInfrastructure(builder.Configuration);

    // в”Җв”Җв”Җ Authentication (Supabase JWT вҶ’ HttpOnly Cookie) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    // appsettings: Jwt:Authority = https://{supabase-ref}.supabase.co/auth/v1
    builder.Services.AddJwtBearerFromCookie(builder.Configuration);
    builder.Services.AddAuthorization();

    // в”Җв”Җв”Җ Controllers + Swagger в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddControllers();
    builder.Services.AddEndpointsApiExplorer();
    builder.Services.AddSwaggerGen(options =>
    {
        options.SwaggerDoc("v1", new OpenApiInfo
        {
            Title = "{{name}} API",
            Version = "v1",
            Description = "{{name}} Clean Architecture API"
        });
        var xmlFile = $"{System.Reflection.Assembly.GetExecutingAssembly().GetName().Name}.xml";
        var xmlPath = Path.Combine(AppContext.BaseDirectory, xmlFile);
        if (File.Exists(xmlPath)) options.IncludeXmlComments(xmlPath);
    });

    // в”Җв”Җв”Җ Health Checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddHealthChecks();

    // в”Җв”Җв”Җ CORS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddCors(options =>
    {
        options.AddPolicy("AllowedOrigins", policy =>
            policy.WithOrigins(
                    builder.Configuration["Cors:AllowedOrigins"]?.Split(',') ?? [])
                  .AllowAnyMethod()
                  .AllowAnyHeader()
                  .AllowCredentials());
    });

    // в”Җв”Җв”Җ Problem Details (RFC 7807) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddProblemDetails();

    // в”Җв”Җв”Җ Rate Limiting (кі м • м°Ҫ, л¶„лӢ№ 100нҡҢ/нҒҙлқјмқҙм–ёнҠё) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    builder.Services.AddRateLimiter(options =>
    {
        options.GlobalLimiter = PartitionedRateLimiter.Create<HttpContext, string>(ctx =>
            RateLimitPartition.GetFixedWindowLimiter(
                partitionKey: ctx.User.Identity?.Name ?? ctx.Request.Headers.Host.ToString(),
                factory: _ => new FixedWindowRateLimiterOptions
                {
                    AutoReplenishment = true,
                    PermitLimit = 100,
                    Window = TimeSpan.FromMinutes(1)
                }));
        options.OnRejected = async (ctx, ct) =>
        {
            ctx.HttpContext.Response.StatusCode = StatusCodes.Status429TooManyRequests;
            await ctx.HttpContext.Response.WriteAsync(
                "мҡ”мІӯмқҙ л„Ҳл¬ҙ л§ҺмҠөлӢҲлӢӨ. мһ мӢң нӣ„ лӢӨмӢң мӢңлҸ„н•ҙмЈјм„ёмҡ”.", ct);
        };
    });

    // в”Җв”Җв”Җ Build в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    var app = builder.Build();

    // в”Җв”Җв”Җ Exception Handler (ValidationExceptionвҶ’400, UnauthorizedвҶ’403, elseвҶ’500)
    app.UseValidationExceptionHandler();

    // в”Җв”Җв”Җ Middleware Pipeline в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if (app.Environment.IsDevelopment())
    {
        app.UseSwagger();
        app.UseSwaggerUI(c => c.SwaggerEndpoint("/swagger/v1/swagger.json", "{{name}} API v1"));
    }

    if (!app.Environment.IsDevelopment())
    {
        app.UseHttpsRedirection();
        app.UseHsts();
    }

    app.UseSerilogRequestLogging();
    app.UseRateLimiter();
    app.UseCors("AllowedOrigins");
    app.UseAuthentication();
    app.UseAuthorization();
    app.MapControllers();
    app.MapHealthChecks("/health");
    app.MapHealthChecks("/health/ready");

    app.Run();
}
catch (Exception ex) when (ex is not HostAbortedException)
{
    Log.Fatal(ex, "м• н”ҢлҰ¬мјҖмқҙм…ҳ мӢңмһ‘ мӨ‘ мҳӨлҘҳ л°ңмғқ");
}
finally
{
    Log.CloseAndFlush();
}
